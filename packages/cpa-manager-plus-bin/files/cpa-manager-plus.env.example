# CPA Manager Plus configuration for the AUR package.
# Copy this file to ~/.config/cpa-manager-plus/cpa-manager-plus.env and edit
# the secrets before starting cpa-manager-plus.service:
#   install -Dm600 /usr/share/doc/cpa-manager-plus-bin/cpa-manager-plus.env.example ~/.config/cpa-manager-plus/cpa-manager-plus.env
#   $EDITOR ~/.config/cpa-manager-plus/cpa-manager-plus.env
#   systemctl --user enable --now cpa-manager-plus.service

# Manager server listen address. The upstream native default is 0.0.0.0:18317;
# this package defaults to localhost to avoid exposing the dashboard by accident.
HTTP_ADDR=127.0.0.1:18317

# CLIProxyAPI/CPA base URL and management key. This may point to either a local
# cli-proxy-api service or a remote CPA endpoint. For local CPA with default
# settings, use http://127.0.0.1:8317.
#
# CPA should have usage-statistics-enabled: true for usage collection.
# Use the plaintext CPA Management Key here, not the bcrypt hash that CPA may
# write back to its config after startup.
CPA_UPSTREAM_URL=http://127.0.0.1:8317
CPA_MANAGEMENT_KEY=replace-with-your-management-key

# Manager dashboard/admin API key. This is the key used to log in to the
# cpa-manager-plus web UI and is separate from CPA_MANAGEMENT_KEY.
#
# Important: CPA Manager Plus stores this key as a digest in its SQLite database
# on first initialization. After the service has initialized, changing this env
# value alone does not change the login key. To rotate it, stop the service and run:
#   printf '%s\n' 'replace-with-your-admin-key' > /tmp/cpamp-admin-key
#   cpa-manager-plus reset-admin-key --db-path ~/.local/state/cpa-manager-plus/usage.sqlite --admin-key-file /tmp/cpamp-admin-key
#   rm -f /tmp/cpamp-admin-key
#   systemctl --user restart cpa-manager-plus.service
CPA_MANAGER_ADMIN_KEY=replace-with-your-admin-key

# Usage collector settings. Keep only one Manager Server consuming the same
# CLIProxyAPI/CPA usage queue.
USAGE_COLLECTOR_MODE=auto
USAGE_RESP_QUEUE=usage
USAGE_RESP_POP_SIDE=right
USAGE_BATCH_SIZE=100
USAGE_POLL_INTERVAL_MS=500
USAGE_QUERY_LIMIT=50000
USAGE_CORS_ORIGINS=*
USAGE_RESP_TLS_SKIP_VERIFY=false

# Optional panel subpath for reverse-proxy deployments, such as /cpa.
PANEL_PATH=

# The user service sets these paths to the XDG state directory:
# ~/.local/state/cpa-manager-plus, or $XDG_STATE_HOME/cpa-manager-plus when XDG_STATE_HOME is set.
# Uncomment only when running cpa-manager-plus manually without the user service.
# USAGE_DATA_DIR=./data
# USAGE_DB_PATH=./data/usage.sqlite
# CPA_MANAGER_DATA_KEY_PATH=./data/data.key
