# CPA Usage Keeper configuration for the AUR package.
# Copy this file to /etc/cpa-usage-keeper.env and edit the secrets before starting cpa-usage-keeper.service.

# CLIProxyAPI base URL. CLIProxyAPI must have usage-statistics-enabled: true.
CPA_BASE_URL=http://127.0.0.1:8317

# CLIProxyAPI management key.
CPA_MANAGEMENT_KEY=replace-with-your-management-key

# Built-in dashboard login protection. Enable this if the dashboard is reachable by other users.
AUTH_ENABLED=false
LOGIN_PASSWORD=replace-with-your-login-password
AUTH_SESSION_TTL=168h

# Dashboard listen port and optional reverse-proxy subpath such as /cpa.
APP_PORT=8080
APP_BASE_PATH=

# Optional native TLS. Most deployments should terminate HTTPS at a reverse proxy instead.
TLS_ENABLED=false
TLS_CERT_FILE=
TLS_KEY_FILE=

# Business timezone used by daily usage aggregation and logs.
TZ=Asia/Shanghai

# CPA Redis/RESP usage queue. Leave empty to derive host:8317 from CPA_BASE_URL.
REDIS_QUEUE_ADDR=
REDIS_QUEUE_TLS=false
REDIS_QUEUE_BATCH_SIZE=1000
REDIS_QUEUE_IDLE_INTERVAL=1s

# Runtime storage managed by systemd StateDirectory=cpa-usage-keeper.
WORK_DIR=/var/lib/cpa-usage-keeper

REQUEST_TIMEOUT=30s
TLS_SKIP_VERIFY=false
LOG_LEVEL=info
LOG_FILE_ENABLED=true
LOG_RETENTION_DAYS=7
BACKUP_ENABLED=true
BACKUP_INTERVAL=24h
BACKUP_RETENTION_DAYS=7
